# Binance Spot live keys. Only enable spot trading/read permissions; never enable withdrawals.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Safety defaults. Keep EXECUTE_TRADES=false until you manually enable trading in the web panel.
BINANCE_BASE_URL=https://api.binance.com
BINANCE_SYMBOL=BTCUSDT
BINANCE_QUOTE_ASSET=USDT
BINANCE_BASE_ASSET=BTC
EXECUTE_TRADES=false

# Strategy/risk knobs.
ORDER_QUOTE_SIZE=5.5
AUTO_POSITION_SIZING=true
GRID_STEP_PCT=0.006
TAKE_PROFIT_PCT=0.006
MAX_POSITION_QUOTE=47
MAX_DAILY_LOSS_QUOTE=50
LOOP_SECONDS=30
DASHBOARD_PASSWORD=change-me
TRADING_FEE_RATE=0.001
MAX_FLOATING_LOSS_QUOTE=5
RAPID_DROP_PAUSE_PCT=0.008
LARGE_DROP_PAUSE_PCT=0.02
REBOUND_BUY_PCT=0.0015
PRICE_ANOMALY_PCT=0.02
DEFENSIVE_MODE=true
DEFENSIVE_POSITION_USAGE_TRIGGER=0.80
DEFENSIVE_FLOATING_LOSS_QUOTE=2.5
DEFENSIVE_RECENT_DRAWDOWN_PCT=0.025
DEFENSIVE_NORMAL_ADD_ON_STEP_PCT=0.0025
DEFENSIVE_ADD_ON_STEP_PCT=0.005
DEFENSIVE_AGED_LOT_DAYS_1=7
DEFENSIVE_AGED_LOT_PROFIT_PCT_1=0.0035
DEFENSIVE_AGED_LOT_DAYS_2=14
DEFENSIVE_AGED_LOT_PROFIT_PCT_2=0.0015
SWING_STRATEGY=true
SWING_ALLOCATION_PCT=0.30
SWING_MIN_ORDER_QUOTE=10
SWING_MAX_ORDER_QUOTE=15
SWING_ADD_STEP_PCT=0.015
SWING_MIN_BAND_PCT=0.012
SWING_MAX_BAND_PCT=0.025
SWING_MANUAL_CENTER_PRICE=0
SWING_KLINE_INTERVAL=1h
SWING_KLINE_LIMIT=24
TREND_GUARD=true
TREND_NORMAL_POOL_PCT=0.30
TREND_DIP_POOL_PCT=0.10
TREND_DIP_ORDER_QUOTE=3
TREND_REBOUND_PCT=0.005
TREND_KLINE_INTERVAL=1h
TREND_KLINE_LIMIT=240
DEFENSIVE_SCALP=true
DEFENSIVE_SCALP_ALLOCATION_PCT=0.08
DEFENSIVE_SCALP_ORDER_PCT=0.018
DEFENSIVE_SCALP_MIN_ORDER_QUOTE=6
DEFENSIVE_SCALP_MAX_ORDER_QUOTE=10
DEFENSIVE_SCALP_BUY_DROP_PCT=0.004
DEFENSIVE_SCALP_TAKE_PROFIT_PCT=0.005
DEFENSIVE_SCALP_ADD_STEP_PCT=0.003
DEFENSIVE_SCALP_MIN_RANGE_PCT=0.004
DEFENSIVE_SCALP_MAX_RANGE_PCT=0.018
MANUAL_BUY_AUTO_SELL=false
TRADING_TOGGLE_PASSWORD=change-me
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=交易报告
REPORT_RECIPIENT=
