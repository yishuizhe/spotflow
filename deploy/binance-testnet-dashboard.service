[Unit]
Description=Binance Spot Live Agent Dashboard
After=network-online.target binance-testnet-agent.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/binance-testnet-agent
EnvironmentFile=/opt/binance-testnet-agent/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 -m binance_testnet_agent.dashboard --host 0.0.0.0 --port 8088
Restart=always
RestartSec=10
User=ubuntu
Group=ubuntu

[Install]
WantedBy=multi-user.target
